# ==========================
# AI-COMPANY
# ==========================

APP_NAME=AI-COMPANY
ENVIRONMENT=development
DEBUG=true

# ==========================
# OpenAI
# ==========================

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5

# ==========================
# Gemini
# ==========================

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# ==========================
# Claude
# ==========================

ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4

# ==========================
# Local Model (Ollama)
# ==========================

LOCAL_MODEL_URL=http://localhost:11434
LOCAL_MODEL_NAME=llama3.1

# ==========================
# GitHub
# ==========================

GITHUB_TOKEN=
GITHUB_REPOSITORY=

# ==========================
# Telegram
# ==========================

TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=

# ==========================
# PostgreSQL
# ==========================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_company
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# ==========================
# Redis
# ==========================

REDIS_HOST=localhost
REDIS_PORT=6379

# ==========================
# ChromaDB
# ==========================

CHROMA_HOST=localhost
CHROMA_PORT=8001

# ==========================
# Security
# ==========================

JWT_SECRET=
API_KEY=

# ==========================
# Dashboard
# ==========================

DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=3000

# ==========================
# Backend
# ==========================

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
